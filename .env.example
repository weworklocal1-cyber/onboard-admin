# ===========================================
# LocalWala Food - Environment Configuration
# Copy this file to .env.local and fill in your values
# ===========================================

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ===========================================
# Supabase Database (required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin password for /admin panel
ADMIN_PASSWORD=change_me_to_a_strong_password

# Google Apps Script Web App URL (optional fallback)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_script_id/exec

# App Configuration
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=LocalWala Food
NEXT_PUBLIC_APP_TAGLINE=Delivering Local. Empowering Businesses.

# Contact Details (shown in footer, contact page, etc.)
NEXT_PUBLIC_CONTACT_EMAIL=hello@localwala.tech
NEXT_PUBLIC_CONTACT_PHONE=+91 00000 00000
NEXT_PUBLIC_CONTACT_ADDRESS=Your address here
NEXT_PUBLIC_CONTACT_WORKING_HOURS=Mon - Sat: 9:00 AM - 6:00 PM

# Social Links
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/localwalafood
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/localwalafood
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/localwalafood
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@localwalafood

# Open Graph / SEO
NEXT_PUBLIC_OG_IMAGE=/og-image.png
NEXT_PUBLIC_TWITTER_HANDLE=@localwalafood

# Resend Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@localwala.tech
