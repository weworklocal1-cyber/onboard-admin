# ===========================================
# LocalWala Food - Environment Configuration
# Copy this file to .env.local and fill in your values
# ===========================================

# ===========================================
# Supabase (required for database)
# Get these from: Supabase Dashboard > Settings > API
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://civyjfiyljcuwgfqbytm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_f-47RhwrbkpuZOQp_Yd0cQ_GacO1nHT

# Admin password for /admin panel (change this!)
ADMIN_PASSWORD=Localwala@2025

# Resend API key (for sending emails from admin)
# Get your free key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# WhatsApp Business API (optional)
# Get from Meta Developer Console > WhatsApp > API Setup
# Required env vars: WHATSAPP_API_TOKEN and WHATSAPP_PHONE_NUMBER_ID
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Google Apps Script Web App URL (optional fallback)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LocalWala Food
NEXT_PUBLIC_APP_TAGLINE=Delivering Local. Empowering Businesses.

# Contact Details (shown in footer, contact page, etc.)
NEXT_PUBLIC_CONTACT_EMAIL=partners@localwalafood.com
NEXT_PUBLIC_CONTACT_PHONE=+91 83417 14637
NEXT_PUBLIC_CONTACT_ADDRESS=Dulapally kompally, Hyderabad, Telangana, India
NEXT_PUBLIC_CONTACT_WORKING_HOURS=Mon - Sat: 9:00 AM - 6:00 PM

# Social Links
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/localwalafood
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/localwalafood
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/localwalafood
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@localwalafood

# Open Graph / SEO
